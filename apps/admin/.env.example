# Convex deployment URL (same deployment as www)
CONVEX_URL=

# Shared secret for Convex service functions (must match Convex env SERVICE_KEY)
SERVICE_KEY=

# nuxt-auth-utils session encryption secret (32+ random chars)
NUXT_SESSION_PASSWORD=

# Public CDN host for R2 media previews
NUXT_PUBLIC_CDN_HOST=cdn.institutobitcoin.pt

# Admin accounts are invite-only: create rows in the Convex dashboard
# (adminUsers table: { email, active: true }); the invitee sets their
# password on first login.
