# Convex (dev deployment URL; convex deploy injects it on Vercel)
CONVEX_URL=

# Shared secret for Convex service mutations (must match Convex env SERVICE_KEY)
SERVICE_KEY=

# Absolute site URL (used for payment redirects)
APP_URL=http://localhost:3000

# Stripe
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenNode (BTC donations)
OPENNODE_API_KEY=

# Substack silent-subscribe base URL (optional)
SUBSTACK_URL=
